# ──────────────────────────────────────────────────────────────
# ERPNext Docker Configuration
# Copy this file to .env and update the values before deploying
# ──────────────────────────────────────────────────────────────

# Site name (used as the Frappe site identifier)
SITE_NAME=erpnext.localhost

# Custom image settings (used if you push to a registry)
CUSTOM_IMAGE=erpnext
CUSTOM_TAG=latest

# Exposed port
HTTP_PORT=8002

# MariaDB credentials
DB_ROOT_PASSWORD=changeme
DB_NAME=erpnext
DB_USER=erpnext
DB_PASSWORD=erpnext

# ERPNext admin password (used during site creation)
ADMIN_PASSWORD=admin
